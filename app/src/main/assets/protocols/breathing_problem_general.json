        "lie down"
      ],
      "asset_refs": []
    },
    {
      "step_id": "loosen_clothing",
      "canonical_text": "Loosen any tight clothing around the neck, chest, or waist.",
      "must_keep_keywords": [
        "loosen",
        "tight clothing"
      ],
      "forbidden_keywords": [],
      "asset_refs": []
    },
    {
      "step_id": "reassure_and_pace_breathing",
      "canonical_text": "Stay calm and reassure them. Encourage slow, steady breaths.",
      "must_keep_keywords": [
        "reassure",
        "slow"
      ],
      "forbidden_keywords": [],
      "asset_refs": []
    },
    {
      "step_id": "fresh_air_if_environmental",
      "canonical_text": "If the air is smoky, dusty, or the area feels stuffy, move them to fresh air or open a window.",
      "must_keep_keywords": [
        "fresh air"
      ],
      "forbidden_keywords": [],
      "asset_refs": []
    },
    {
      "step_id": "help_with_prescribed_inhaler",
      "canonical_text": "If they have a prescribed inhaler or breathing medication, help them use it as directed on the device.",
