{
  "tree_id": "stroke_fast_tree",
  "version": "1.0",
  "start_node": "confirm_fast_signs",
  "nodes": [
    {
      "id": "confirm_fast_signs",
      "type": "question",
      "prompt": "Do they have face drooping, arm weakness, or slurred speech? Note the time symptoms started now.",
