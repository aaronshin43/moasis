      "transitions": [
        {
          "when": "yes",
          "to": "stroke_fast_protocol"
        },
        {
          "when": "no",
          "to_tree": "general_assessment_tree"
        }
      ]
    },
    {
      "id": "stroke_fast_protocol",
      "type": "instruction",
      "instruction_id": "stroke_fast_general",
      "next": "stroke_fast_terminal"
    },
    {
      "id": "stroke_fast_terminal",
      "type": "terminal"
    }
  ]
}
