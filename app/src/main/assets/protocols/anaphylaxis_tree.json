          "when": "yes",
          "to": "anaphylaxis_protocol"
        },
        {
          "when": "no",
          "to_tree": "general_assessment_tree"
        }
      ]
    },
    {
      "id": "anaphylaxis_protocol",
      "type": "instruction",
      "instruction_id": "anaphylaxis_general",
      "next": "anaphylaxis_terminal"
    },
    {
      "id": "anaphylaxis_terminal",
      "type": "terminal"
    }
  ]
